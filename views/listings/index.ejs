 <script>
let toggle = document.getElementById("switchCheckReverse");
toggle.addEventListener("click", () => {
  let tax = document.getElementsByClassName("after-tax");
  let toggleText = document.getElementById("toggle-text");
  for (info of tax) {
    if (info.style.display != "inline") {
      info.style.display = "inline";
      toggleText.innerText = "Display total before taxes";
    } else {
      info.style.display = "none";
      toggleText.innerText = "Display total after taxes";
    }
  }
});

const icons = document.querySelectorAll(".category-icon");
const listingsContainer = document.querySelector(".listings-container");
let allListingsData = [...<%- JSON.stringify(allListings || []) %>]; // Ensure allListings is defined

icons.forEach(icon => {
  icon.addEventListener("click", () => {
    const selectedCategory = icon.getAttribute("data-filter");
    const filteredListings = allListingsData.filter(listing => listing.category === selectedCategory);
    renderListings(filteredListings);
  });
});

function searchCountry() {
  const input = document.getElementById("countrySearch");
  const filter = input.value.toLowerCase();
  const filteredListings = allListingsData.filter(listing => 
    listing.country?.toLowerCase().includes(filter) || 
    listing.location?.toLowerCase().includes(filter)
  );
  renderListings(filteredListings);
}

function renderListings(listings) {
  listingsContainer.innerHTML = ""; // Clear existing listings
  listings.forEach(list => {
    const listingHTML = `
      <a href="/listing/${list._id}" class="listing-link">
        <div class="card col listing country-card" data-country="${list.country || ''}" data-location="${list.location || ''}" data-category="${list.category || ''}">
          <div class="card-img-overlay">
            <p class="card-text"></p>
          </div>
          <img src="${list.image || '/default-image.jpg'}" class="card-img-top" alt="listing-image">
          <div class="card-body">
            <p class="card-text"><b>${list.title || 'Untitled'}</b><br>
              &#8377 ${list.price?.toLocaleString("en-IN") || 'N/A'} &nbsp; &nbsp;<i class="after-tax">+18% gst</i>
            </p>
          </div>
        </div>
      </a>
    `;
    listingsContainer.insertAdjacentHTML("beforeend", listingHTML);
  });
}

// Initial render to ensure all listings are displayed
renderListings(allListingsData);
</script>
